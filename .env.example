PORT=3000
NODE_ENV=development
DB_HOST=localhost
DB_PORT=3306
DB_USER=your-hostinger-mysql-user
DB_PASSWORD=your-hostinger-mysql-password
DB_NAME=your-hostinger-mysql-database
SESSION_DAYS=30

# Used only by `npm run db:migrate`; do not configure these in Hostinger runtime.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
MIGRATION_USERS_JSON={"you@example.com":"temporary-password-change-me"}
